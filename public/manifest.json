{
  "manifest_version": 3,
  "name": "repo2txt",
  "version": "2.0.0",
  "description": "Convert GitHub repositories and local folders to plain text for LLM prompts. Chrome extension by Michael Farah.",
  "homepage_url": "https://github.com/michael-farah/repo2txt-extension",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Open repo2txt",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": ["https://api.github.com/*"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "exclude_matches": [
        "https://github.com/*/*/pull/*",
        "https://github.com/*/*/issues/*",
        "https://github.com/*/*/wiki/*",
        "https://github.com/*/*/actions/*",
        "https://github.com/*/*/projects/*",
        "https://github.com/*/*/security/*",
        "https://github.com/*/*/pulse/*",
        "https://github.com/*/*/settings/*"
      ],
      "js": ["content-scripts/github.js"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
